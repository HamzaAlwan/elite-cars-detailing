---
/**
 * P3-T1 — Sticky glass nav shell.
 * Desktop: logo + anchor links + Book CTA.
 * Mobile (JS): Vue MobileNav drawer island.
 * Mobile (no-JS): plain visible nav links in <noscript>.
 */
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import MobileNav from '@/components/islands/MobileNav.vue';
import { CTA } from '@/data/site';

const links = [
  { href: '#value', label: 'Services' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#how-it-works', label: 'How It Works' },
  { href: '#work', label: 'Our Work' },
  { href: '#service-area', label: 'Service Area' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="nav-glass sticky top-0 z-50 border-b border-border" transition:persist>
  <Container class="flex h-16 items-center justify-between gap-5">
    <!-- Logo: back-to-top anchor -->
    <a
      href="#"
      aria-label="Elite Mobile Car Detailing — back to top"
      class="shrink-0 rounded-md focus-visible:outline-brand"
    >
      <img
        src="/logo-no-text.png"
        alt="Elite Mobile Car Detailing"
        width="180"
        height="36"
        loading="eager"
        decoding="sync"
        class="h-8 w-auto"
      />
    </a>

    <!-- Desktop nav links (hidden on mobile) -->
    <nav
      id="desktop-main-nav"
      aria-label="Main navigation"
      class="hidden items-center gap-6 text-sm lg:flex"
    >
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            class="nav-link"
            data-desktop-nav-link
            data-nav-target={href}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- Right side: Book CTA + Vue mobile nav (JS only) -->
    <div class="flex shrink-0 items-center gap-3">
      <Button href="#book" class="hidden sm:inline-flex lg:min-h-10 lg:px-5 lg:text-sm">{CTA.book}</Button>
      <div class="lg:hidden">
        <!-- client:only — Teleport + Transition cannot SSR-hydrate safely with Astro View Transitions -->
        <MobileNav client:only="vue">
          <button
            slot="fallback"
            type="button"
            class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-border bg-bg-elevated/80 text-text"
            aria-hidden="true"
            tabindex="-1"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <line x1="4" y1="7" x2="20" y2="7"></line>
              <line x1="4" y1="12" x2="20" y2="12"></line>
              <line x1="4" y1="17" x2="20" y2="17"></line>
            </svg>
          </button>
        </MobileNav>
      </div>
    </div>
  </Container>

  <!-- No-JS: plain mobile nav links (no fake hamburger — nothing can toggle without JS) -->
  <noscript>
    <nav aria-label="Mobile navigation" class="border-t border-border lg:hidden">
      <Container class="flex flex-col gap-1 py-4">
        {
          links.map(({ href, label }) => (
            <a
              href={href}
              class="min-h-11 rounded-lg px-3 py-2.5 text-sm font-medium text-text-muted transition-colors hover:bg-bg-elevated hover:text-text"
            >
              {label}
            </a>
          ))
        }
        <div class="mt-3 border-t border-border pt-3">
          <Button href="#book" class="w-full">{CTA.book}</Button>
        </div>
      </Container>
    </nav>
  </noscript>
</header>

<script>
  interface NavWindow extends Window {
    __desktopNavBound?: boolean;
  }

  function getDesktopLinks(): HTMLAnchorElement[] {
    return Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-desktop-nav-link][data-nav-target]'),
    );
  }

  function setActiveDesktopLink(targetHash: string): void {
    const links = getDesktopLinks();
    for (const link of links) {
      const href = link.getAttribute('data-nav-target') ?? '';
      const isActive = href === targetHash;
      link.classList.toggle('is-active', isActive);
      if (isActive) {
        link.setAttribute('aria-current', 'true');
      } else {
        link.removeAttribute('aria-current');
      }
    }
  }

  function bindDesktopNav(): void {
    const w = window as NavWindow;
    if (w.__desktopNavBound) return;
    w.__desktopNavBound = true;

    const links = getDesktopLinks();
    const sections = links
      .map((link) => link.getAttribute('data-nav-target') ?? '')
      .map((hash) => document.querySelector<HTMLElement>(hash))
      .filter((section): section is HTMLElement => section instanceof HTMLElement);

    if (!('IntersectionObserver' in window) || sections.length === 0) {
      const initialHash = location.hash || '#value';
      setActiveDesktopLink(initialHash);
      return;
    }

    const ratios = new Map<string, number>();
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const id = (entry.target as HTMLElement).id;
          if (!id) continue;
          ratios.set(id, entry.isIntersecting ? entry.intersectionRatio : 0);
        }

        let bestId = '';
        let bestRatio = 0;
        for (const [id, ratio] of ratios.entries()) {
          if (ratio > bestRatio) {
            bestRatio = ratio;
            bestId = id;
          }
        }
        if (!bestId) return;
        const targetId = bestId;
        setActiveDesktopLink(`#${targetId}`);
      },
      { threshold: [0.25, 0.45, 0.7], rootMargin: '-20% 0px -55% 0px' },
    );

    sections.forEach((section) => observer.observe(section));
    setActiveDesktopLink(location.hash || '#value');
  }

  document.addEventListener('astro:page-load', bindDesktopNav);
  bindDesktopNav();
</script>
