---
/**
 * Cinematic hero scene — pure CSS/SVG stand-in until the owner supplies a real photo (Phase 9).
 * Swap contract: occupies the EXACT box the photo will use (w-full max-w-lg aspect-[4/3]
 * rounded-2xl), so `hasHeroImage ? <img/> : <HeroScene/>` in Hero.astro is layout-identical.
 * Decorative only (aria-hidden). Layers: night wash → ambient glow → light streak →
 * coupe silhouette with brand rim-light (draw-on via scroll reveal) → floor line → reflection.
 * All decoration absolute + transform/opacity only → CLS-safe.
 */
---

<div
  class="surface-raised relative aspect-[4/3] w-full max-w-lg overflow-hidden"
  aria-hidden="true"
>
  <!-- L1: night-sky wash — layered near-black, never flat -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, #0b1020 0%, #0d1019 55%, #06080f 100%);"
  >
  </div>

  <!-- L2: ambient glow behind the car -->
  <div
    class="absolute left-1/2 top-[62%] h-56 w-[130%] -translate-x-1/2 -translate-y-1/2 rounded-full"
    style="background: radial-gradient(closest-side, var(--color-brand-glow-soft), transparent 70%);"
  >
  </div>

  <!-- L3: diagonal light streak -->
  <div
    class="absolute left-[-10%] top-[26%] h-px w-[120%] -rotate-6"
    style="background: linear-gradient(90deg, transparent, var(--color-brand-bright), transparent); opacity: 0.5;"
  >
  </div>

  <!-- L4: coupe silhouette — dark body, brand rim-light stroke draws on when revealed -->
  <svg
    class="hero-draw absolute inset-x-8 bottom-[24%] w-[calc(100%-4rem)]"
    viewBox="0 0 480 150"
    fill="none"
  >
    <defs>
      <linearGradient id="hero-body" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#151926"></stop>
        <stop offset="1" stop-color="#06080f"></stop>
      </linearGradient>
      <linearGradient id="hero-rim" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#5b8cff"></stop>
        <stop offset="0.7" stop-color="#5b8cff" stop-opacity="0.25"></stop>
        <stop offset="1" stop-color="#5b8cff" stop-opacity="0"></stop>
      </linearGradient>
    </defs>
    <!-- body -->
    <path
      pathLength="1"
      d="M18 118
         C10 106 14 92 34 88
         C56 83 70 78 88 70
         C116 55 156 46 204 44
         C252 42 292 50 322 62
         C352 73 392 81 428 89
         C450 94 460 102 456 112
         L446 118
         L412 118
         A30 30 0 0 0 352 118
         L130 118
         A30 30 0 0 0 70 118
         Z"
      fill="url(#hero-body)"
      stroke="url(#hero-rim)"
      stroke-width="1.5"
      stroke-linecap="round"></path>
    <!-- glasshouse beltline -->
    <path
      pathLength="1"
      d="M112 68 C144 54 184 48 214 48 C258 48 288 54 314 64"
      stroke="rgb(255 255 255 / 0.09)"
      stroke-width="1.25"
      stroke-linecap="round"></path>
    <!-- wheels -->
    <circle cx="100" cy="118" r="17" fill="#0b0e17" stroke="rgb(255 255 255 / 0.14)" stroke-width="1.5"></circle>
    <circle cx="382" cy="118" r="17" fill="#0b0e17" stroke="rgb(255 255 255 / 0.14)" stroke-width="1.5"></circle>
    <circle cx="100" cy="118" r="5.5" fill="none" stroke="rgb(91 140 255 / 0.35)" stroke-width="1.25"></circle>
    <circle cx="382" cy="118" r="5.5" fill="none" stroke="rgb(91 140 255 / 0.35)" stroke-width="1.25"></circle>
  </svg>

  <!-- L5: floor line -->
  <div
    class="absolute inset-x-0 bottom-[24%] h-px"
    style="background: linear-gradient(90deg, transparent, rgb(255 255 255 / 0.14), transparent);"
  >
  </div>

  <!-- L6: floor reflection — mirrored simplified body, masked to fade out -->
  <svg
    class="absolute inset-x-8 bottom-[3%] w-[calc(100%-4rem)] -scale-y-100 opacity-20"
    style="mask-image: linear-gradient(0deg, transparent 25%, black 90%); -webkit-mask-image: linear-gradient(0deg, transparent 25%, black 90%);"
    viewBox="0 0 480 150"
    fill="none"
  >
    <path
      d="M18 118
         C10 106 14 92 34 88
         C56 83 70 78 88 70
         C116 55 156 46 204 44
         C252 42 292 50 322 62
         C352 73 392 81 428 89
         C450 94 460 102 456 112
         L446 118
         L412 118
         A30 30 0 0 0 352 118
         L130 118
         A30 30 0 0 0 70 118
         Z"
      fill="#0d1019"></path>
  </svg>
</div>
