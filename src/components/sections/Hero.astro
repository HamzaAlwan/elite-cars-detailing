---
/**
 * P3-T2 — Hero section (above the fold).
 * Layout: single column on mobile → 2-col (copy | image) on desktop (lg:grid-cols-2).
 * Image: <img> with explicit dimensions + fetchpriority="high" + loading="eager" for LCP.
 * OWNER: Replace HERO_IMAGE_SRC with the real photo path once supplied (Phase 9).
 *   e.g. '/images/hero-car-detail.jpg' — AVIF/WebP versions in public/images/
 * Cold-start: no fabricated star rating. Trust strip + guarantee badge instead.
 * Glow: static radial gradient (NOT backdrop-filter — iOS 18 safe §2.5).
 */
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import { SITE, CTA, CONTACT } from '@/data/site';
import { hasConfiguredPhone } from '@/lib/contact';

// Owner replaces this with the real hero photo path in Phase 9.
// Set to empty string to show the decorative logo silhouette instead.
const HERO_IMAGE_SRC = ''; // e.g. '/images/hero-car-detail.jpg'
const hasHeroImage = HERO_IMAGE_SRC.length > 0;

interface HeroProofChip {
  label: string;
}

const heroProofChips: HeroProofChip[] = [
  { label: '50-mile DFW coverage' },
  { label: 'No upfront payment' },
  { label: 'Fully self-contained rig' },
];
---

<section
  id="hero"
  class="relative flex min-h-[100svh] items-center overflow-hidden py-24"
>
  <!-- Decorative sapphire radial glow (background gradient, NOT backdrop-filter — iOS safe §2.5) -->
  <div
    class="pointer-events-none absolute right-0 top-1/4 h-[500px] w-[500px] -translate-y-1/4 translate-x-1/4 rounded-full"
    style="background: radial-gradient(closest-side, rgba(30,95,255,.22), transparent);"
    aria-hidden="true"
  ></div>

  <Container class="relative">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">

      <!-- Left column: copy -->
      <div>
        <p
          data-reveal
          data-reveal-index="0"
          class="text-xs font-semibold tracking-[0.18em] text-text-muted uppercase"
        >
          Premium Mobile Detailing
        </p>

        <!-- Headline — the page's only h1 -->
        <h1
          data-reveal
          data-reveal-index="1"
          class="mt-3 text-h1 font-bold tracking-tight text-text"
        >
          Showroom Shine.<br />
          Delivered to Your Driveway.
        </h1>

        <!-- Subheadline -->
        <p
          data-reveal
          data-reveal-index="2"
          class="mt-6 max-w-2xl text-lg leading-relaxed text-text-muted"
        >
          {SITE.description}
        </p>

        <ul data-reveal data-reveal-index="3" class="mt-5 flex flex-wrap gap-2.5">
          {
            heroProofChips.map((chip) => (
              <li class="inline-flex min-h-9 items-center rounded-full border border-border bg-bg-elevated px-3.5 text-xs font-medium text-text-muted">
                {chip.label}
              </li>
            ))
          }
        </ul>

        <!-- CTA group -->
        <div
          data-reveal
          data-reveal-index="4"
          class="mt-8 flex flex-wrap items-center gap-3.5"
        >
          <Button href="#book">{CTA.book}</Button>
          <Button href="#quote" variant="secondary">{CTA.quote}</Button>
          <!-- Tap-to-call (mobile-prominent) — hidden until real number is set in site.ts -->
          {hasConfiguredPhone(CONTACT.phoneE164) && (
            <a
              href={`tel:${CONTACT.phoneE164}`}
              class="inline-flex min-h-11 cursor-pointer items-center gap-2 rounded-full px-4 text-sm font-medium text-text-muted transition-colors hover:text-text sm:hidden"
              aria-label={`Call us at ${CONTACT.phoneDisplay}`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.87-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              {CONTACT.phoneDisplay}
            </a>
          )}
        </div>

        <p data-reveal data-reveal-index="5" class="mt-3 text-sm text-text-muted">
          Response within a few hours. Weather-flexible scheduling.
        </p>

        <!-- Trust strip: icon + label pills -->
        <ul
          data-reveal
          data-reveal-index="6"
          class="mt-6 flex flex-wrap gap-3 text-sm text-text-muted"
          aria-label="Trust highlights"
        >
          <li class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/>
              <path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>
            </svg>
            100% self-contained
          </li>
          <li class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Same-day slots
          </li>
          <li class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
            Insured &amp; vetted
          </li>
        </ul>

        <!-- Satisfaction guarantee badge (cold-start) -->
        <p
          data-reveal
          data-reveal-index="7"
          class="mt-4 flex items-center gap-1.5 text-sm text-text-muted"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          100% satisfaction guaranteed or we come back at no charge
        </p>
      </div>

      <!-- Right column: hero image (desktop) / decorative silhouette fallback -->
      <div
        data-reveal
        data-reveal-index="8"
        class="relative hidden lg:flex lg:items-center lg:justify-center"
      >
        <!-- OWNER: real hero photo — preload in Layout <head> once path is known (Phase 9). -->
        {hasHeroImage ? (
          <img
            src={HERO_IMAGE_SRC}
            alt="A freshly detailed luxury car — showroom finish delivered to your driveway"
            width="600"
            height="450"
            fetchpriority="high"
            loading="eager"
            decoding="async"
            class="w-full max-w-lg rounded-2xl object-cover shadow-2xl"
          />
        ) : (
          <div class="surface-raised relative w-full max-w-lg overflow-hidden rounded-2xl p-8">
            <div
              class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full"
              style="background: radial-gradient(closest-side, rgba(30,95,255,.28), transparent);"
              aria-hidden="true"
            ></div>
            <p class="text-xs font-semibold tracking-[0.16em] text-text-muted uppercase">
              Signature Experience
            </p>
            <p class="mt-3 max-w-md text-sm leading-relaxed text-text-muted">
              We built this service for owners who want premium care without giving up their day.
              Every visit follows the same quality checklist and final handoff standard.
            </p>
            <img
              src="/logo.png"
              alt=""
              aria-hidden="true"
              width="480"
              height="165"
              class="mt-7 w-full opacity-90"
              loading="eager"
            />
            <ul class="mt-6 space-y-2.5 text-sm text-text-muted">
              <li class="flex items-center gap-2">
                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-brand"></span>
                Dedicated process from arrival to walkthrough
              </li>
              <li class="flex items-center gap-2">
                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-brand"></span>
                Interior and exterior quality checks before handoff
              </li>
              <li class="flex items-center gap-2">
                <span class="inline-flex h-1.5 w-1.5 rounded-full bg-brand"></span>
                Satisfaction-first touch-up policy
              </li>
            </ul>
          </div>
        )}
      </div>

    </div>
  </Container>
</section>

<!-- initReveal() is called once globally in index.astro — no per-section call needed. -->
