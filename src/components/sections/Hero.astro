---
/**
 * Hero — full-bleed cinematic first viewport.
 * Brand + H1 + one sentence + CTAs + one trust line.
 * Floating blue Aventador cutout sits in the right column (in-flow), not absolute-to-viewport.
 * Optional HERO_IMAGE_SRC replaces the cutout with a full-bleed photo (Phase 9).
 */
import Atmosphere from '@/components/ui/Atmosphere.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import { SITE, CTA, CONTACT } from '@/data/site';
import { hasConfiguredPhone } from '@/lib/contact';

const HERO_IMAGE_SRC = ''; // e.g. '/images/hero-car-detail.jpg'
const hasHeroImage = HERO_IMAGE_SRC.length > 0;

const HERO_CAR_WEBP = '/images/hero-car.webp';
const HERO_CAR_PNG = '/images/hero-car.png';

const heroSubcopy =
  'Fully self-contained mobile detailing across Richardson & the DFW metro — we bring water and power to your driveway.';
---

<section
  id="hero"
  class="relative isolate flex min-h-[100svh] items-center overflow-hidden pb-16 pt-28 md:pb-24 md:pt-24"
>
  <Atmosphere variant="hero" />

  <!-- Readability scrim -->
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background:
      linear-gradient(90deg, rgb(6 8 15 / 0.9) 0%, rgb(6 8 15 / 0.55) 42%, rgb(6 8 15 / 0.2) 70%, transparent 100%),
      linear-gradient(180deg, rgb(6 8 15 / 0.5) 0%, transparent 28%, transparent 72%, rgb(6 8 15 / 0.75) 100%),
      radial-gradient(80% 55% at 78% 48%, var(--color-brand-aurora), transparent 65%);"
    aria-hidden="true"
  >
  </div>

  {
    hasHeroImage && (
      <img
        src={HERO_IMAGE_SRC}
        alt=""
        width="1600"
        height="900"
        fetchpriority="high"
        loading="eager"
        decoding="async"
        class="pointer-events-none absolute inset-0 -z-20 h-full w-full object-cover"
        aria-hidden="true"
      />
    )
  }

  <Container class="relative w-full">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-8">
      <div class="relative z-10 max-w-xl">
        <p
          data-reveal
          data-reveal-index="0"
          class="is-visible text-sm font-semibold tracking-tight text-text md:text-base"
        >
          {SITE.name}
        </p>

        <h1
          data-reveal="blur"
          data-reveal-index="1"
          class="is-visible mt-4 text-h1 text-text"
        >
          <span class="text-brand-bright">Showroom Shine.</span><br />
          Delivered to Your Driveway.
        </h1>

        <p
          data-reveal="blur"
          data-reveal-index="2"
          class="is-visible mt-5 max-w-prose text-lg leading-relaxed text-text-muted"
        >
          {heroSubcopy}
        </p>

        <div
          data-reveal
          data-reveal-index="3"
          class="is-visible mt-8 flex flex-wrap items-center gap-3.5"
        >
          <Button href="#book" class="btn-glow btn-glow--pulse">{CTA.book}</Button>
          <Button href="#quote" variant="secondary">{CTA.quote}</Button>
          {
            hasConfiguredPhone(CONTACT.phoneE164) && (
              <a
                href={`tel:${CONTACT.phoneE164}`}
                class="inline-flex min-h-11 cursor-pointer items-center gap-2 rounded-full px-4 text-sm font-medium text-text-muted transition-colors hover:text-text sm:hidden"
                aria-label={`Call us at ${CONTACT.phoneDisplay}`}
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.87-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
                {CONTACT.phoneDisplay}
              </a>
            )
          }
        </div>

        <p
          data-reveal
          data-reveal-index="4"
          class="is-visible mt-5 text-sm text-text-muted"
        >
          100% self-contained · Same-day slots · Insured &amp; vetted
        </p>
      </div>

      {
        !hasHeroImage && (
          <div
            data-reveal
            data-reveal-index="5"
            class="hero-float is-visible relative mx-auto flex w-full max-w-xl items-center justify-center lg:max-w-none lg:justify-end"
            aria-hidden="true"
          >
            <div class="hero-float__car relative w-full max-w-lg lg:max-w-none lg:w-[118%]">
              <picture>
                <source srcset={HERO_CAR_WEBP} type="image/webp" />
                <img
                  src={HERO_CAR_PNG}
                  alt=""
                  width="1920"
                  height="947"
                  fetchpriority="high"
                  loading="eager"
                  decoding="async"
                  class="hero-float__img relative w-full select-none"
                />
              </picture>
            </div>
          </div>
        )
      }
    </div>
  </Container>
</section>
