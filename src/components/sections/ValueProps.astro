---
/**
 * P3-T3 — "Why Choose Elite?" value proposition cards.
 * 4 cards: 1-col → 2-col (sm) → 4-col (lg).
 * Icons are inline SVGs (not @lucide/vue — static section, zero JS; §performance rule).
 * Each card has aria-hidden="true" on the icon and data-reveal stagger.
 */
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';

const props = [
  {
    title: '100% Self-Contained Units',
    body: 'Our rigs bring onboard water and power — we detail anywhere, including apartments and office lots with zero hookup access.',
    icon: /* Droplets */ `<svg class="icon-hover" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>`,
  },
  {
    title: 'DFW Detailing Experts',
    body: 'Certified, vetted, and fully insured. Serving a 50-mile Richardson radius across the DFW metro — Plano, Allen, Frisco, and beyond.',
    icon: /* ShieldCheck */ `<svg class="icon-hover" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  },
  {
    title: 'Advanced Paint Protection',
    body: 'Decontamination, clay bar treatment, and multi-year ceramic coatings — your paint protected and showroom-ready.',
    icon: /* Sparkles */ `<svg class="icon-hover" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l1.88 5.76a2 2 0 0 0 1.26 1.26L21 12l-5.76 1.88a2 2 0 0 0-1.26 1.26L12 21l-1.88-5.76a2 2 0 0 0-1.26-1.26L3 12l5.76-1.88a2 2 0 0 0 1.26-1.26L12 3z"/><path d="M5 3l.6 1.8a1 1 0 0 0 .63.63L8 6l-1.77.57a1 1 0 0 0-.63.63L5 9l-.6-1.8a1 1 0 0 0-.63-.63L2 6l1.77-.57a1 1 0 0 0 .63-.63L5 3z"/><path d="M19 13l.4 1.2a1 1 0 0 0 .63.63L21.2 15l-1.17.37a1 1 0 0 0-.63.63L19 17l-.4-1.2a1 1 0 0 0-.63-.63L16.8 15l1.17-.37a1 1 0 0 0 .63-.63L19 13z"/></svg>`,
  },
  {
    title: 'Weather-Flexible Booking',
    body: 'Texas weather shifts fast. Reschedule in a tap — no fees, no friction. We work around your schedule, not the other way around.',
    icon: /* Clock */ `<svg class="icon-hover" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
];
---

<Section id="value">
  <Container>
    <h2 data-reveal data-reveal-index="0">Why Choose Elite?</h2>
    <p data-reveal data-reveal-index="1" class="mt-3 max-w-2xl text-text-muted">
      Premium mobile detailing, fully self-contained — no hookups, no hassle, just a showroom finish
      wherever you are.
    </p>

    <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        props.map((p, i) => (
          <div
            data-reveal
            data-reveal-index={i + 2}
            class="surface-raised card-hover icon-hover-trigger p-6"
          >
            <div class="text-brand" set:html={p.icon} />
            <h3 class="mt-4 font-semibold text-text">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{p.body}</p>
          </div>
        ))
      }
    </div>
  </Container>
</Section>

<script>
  // Phase 5 — Motion One micro-animation: a subtle scale-in on each value-prop icon as its card
  // enters view. transform-only (no hidden state), gated on reduced-motion. One element per card.
  import { animate, inView } from 'motion';
  import { prefersReducedMotion } from '@/lib/motion';

  if (!prefersReducedMotion()) {
    inView(
      '#value .icon-hover-trigger',
      (el) => {
        const icon = el.querySelector('svg');
        if (icon) {
          animate(
            icon,
            { transform: ['scale(0.7)', 'scale(1)'] },
            { duration: 0.45, ease: [0.05, 0.7, 0.1, 1] },
          );
        }
      },
      { amount: 0.6 },
    );
  }
</script>
