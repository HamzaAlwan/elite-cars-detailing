---
/**
 * P3-T9 — Sticky mobile action bar.
 * Fixed bottom bar: [Book Your Detail] [Call Now] — mobile only (md:hidden).
 * Safe-area insets: padding-bottom = max(12px, env(safe-area-inset-bottom)) (§2.5).
 * transition:persist so ClientRouter doesn't re-animate it on anchor navigation.
 * Body gets matching bottom padding (added via class on <body> in Layout.astro).
 */
import { CTA, CONTACT } from '@/data/site';
---

<div
  class="fixed inset-x-0 bottom-0 z-50 border-t border-border bg-bg-elevated md:hidden"
  style="padding-bottom: max(12px, env(safe-area-inset-bottom));"
  transition:persist
>
  <div class="flex gap-3 px-4 pt-3">
    <a
      href="#book"
      class="btn-metal flex flex-1 cursor-pointer items-center justify-center rounded-full py-3 text-sm font-medium"
    >
      {CTA.book}
    </a>
    {
      CONTACT.phoneE164 !== '{{PHONE_E164}}' ? (
        <a
          href={`tel:${CONTACT.phoneE164}`}
          aria-label={`Call us at ${CONTACT.phoneDisplay}`}
          class="flex min-h-11 flex-1 cursor-pointer items-center justify-center gap-2 rounded-full border border-border text-sm font-medium text-text transition-colors hover:border-border-bright"
        >
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.87-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          Call Now
        </a>
      ) : (
        <a
          href="#quote"
          class="flex min-h-11 flex-1 cursor-pointer items-center justify-center rounded-full border border-border text-sm font-medium text-text transition-colors hover:border-border-bright"
        >
          Get a Quote
        </a>
      )
    }
  </div>
</div>
