---
/**
 * P3-T9 — Sticky mobile action bar.
 * Fixed bottom bar: [Book Your Detail] [Call Now] — mobile only (md:hidden).
 * Safe-area insets: padding-bottom = max(12px, env(safe-area-inset-bottom)) (§2.5).
 * transition:persist so ClientRouter doesn't re-animate it on anchor navigation.
 * Body gets matching bottom padding (added via class on <body> in Layout.astro).
 */
import { CTA, CONTACT } from '@/data/site';
import { hasConfiguredPhone } from '@/lib/contact';
---

<div
  class="surface-glass fixed inset-x-0 bottom-0 z-50 border-x-0 border-b-0 md:hidden"
  style="padding-bottom: max(12px, env(safe-area-inset-bottom));"
  transition:persist
>
  <div class="flex gap-3 px-4 pt-3">
    <a
      id="sticky-primary-cta"
      href="#book"
      class="btn-metal flex flex-1 cursor-pointer items-center justify-center rounded-full py-3 text-sm font-medium"
    >
      <span data-cta-label>{CTA.book}</span>
    </a>
    {
      hasConfiguredPhone(CONTACT.phoneE164) ? (
        <a
          href={`tel:${CONTACT.phoneE164}`}
          aria-label={`Call us at ${CONTACT.phoneDisplay}`}
          class="flex min-h-11 flex-1 cursor-pointer items-center justify-center gap-2 rounded-full border border-border text-sm font-medium text-text transition-colors hover:border-border-bright"
        >
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.59 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.87-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          Call Now
        </a>
      ) : (
        <a
          href="#quote"
          class="flex min-h-11 flex-1 cursor-pointer items-center justify-center rounded-full border border-border text-sm font-medium text-text transition-colors hover:border-border-bright"
        >
          Get a Quote
        </a>
      )
    }
  </div>
</div>

<script>
  type StickyMode = 'default' | 'choose';

  interface StickyWindow extends Window {
    __stickyBarBound?: boolean;
  }

  function getStickyElements(): { primary: HTMLAnchorElement | null; pricing: HTMLElement | null } {
    return {
      primary: document.getElementById('sticky-primary-cta') as HTMLAnchorElement | null,
      pricing: document.getElementById('pricing'),
    };
  }

  const LABEL_FADE_MS = 150;

  function updatePrimaryCta(mode: StickyMode): void {
    const { primary } = getStickyElements();
    if (!primary) return;
    const text = mode === 'choose' ? 'Choose Package' : 'Book Your Detail';
    primary.href = mode === 'choose' ? '#pricing' : '#book';

    const label = primary.querySelector<HTMLElement>('[data-cta-label]');
    if (!label) {
      primary.textContent = text;
      return;
    }
    if (label.textContent === text) return;
    // Fade out → swap → fade in; instant swap when the user prefers reduced motion.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      label.textContent = text;
      return;
    }
    label.classList.add('is-swapping');
    window.setTimeout(() => {
      label.textContent = text;
      label.classList.remove('is-swapping');
    }, LABEL_FADE_MS);
  }

  function bindStickyBehavior(): void {
    const w = window as StickyWindow;
    if (w.__stickyBarBound) return;
    w.__stickyBarBound = true;

    const { pricing } = getStickyElements();
    if (!pricing || !('IntersectionObserver' in window)) return;

    let currentMode: StickyMode = 'default';
    const setMode = (mode: StickyMode): void => {
      if (mode === currentMode) return;
      currentMode = mode;
      updatePrimaryCta(mode);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          setMode(entry.isIntersecting ? 'choose' : 'default');
        }
      },
      {
        // "Choose" mode while #pricing crosses the viewport's middle band — robust at any
        // section height (the old margin+threshold combo misfired on short viewports).
        threshold: 0,
        rootMargin: '-45% 0px -45% 0px',
      },
    );

    observer.observe(pricing);
    updatePrimaryCta('default');
  }

  document.addEventListener('astro:page-load', bindStickyBehavior);
  bindStickyBehavior();
</script>

<style>
  [data-cta-label] {
    transition: opacity 150ms var(--ease-in);
  }
  [data-cta-label].is-swapping {
    opacity: 0;
  }
</style>
