---
/**
 * P5-T1…P5-T6 — Our Work gallery section.
 * Grid of before/after sliders + photo tiles + (future) video clips.
 * Images use astro:assets <Image> / <Picture> for AVIF/WebP + explicit dimensions (no CLS).
 * GLightbox: initialized via inline script on first click (lazy).
 * BeforeAfterSlider: client:visible (only hydrates when scrolled into view).
 *
 * OWNER ACTION REQUIRED: Replace the placeholder `data-placeholder` tiles with real
 * before/after photos. Add images to public/images/work/ as:
 *   before-[slug].jpg + after-[slug].jpg
 * then uncomment the real <BeforeAfterSlider> entries below.
 * Captions format: "Vehicle · City · Package"
 */
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { SOCIAL } from '@/data/site';
// BeforeAfterSlider imported below when real photos are added:
// import BeforeAfterSlider from '@/components/islands/BeforeAfterSlider.vue';

// Placeholder items — replace with real photo paths once owner supplies them (Phase 9)
const placeholderCount = 6;

// Real gallery items will look like this:
// const galleryItems = [
//   {
//     type: 'beforeafter',
//     before: '/images/work/before-bmw-x5.jpg',
//     after: '/images/work/after-bmw-x5.jpg',
//     beforeAlt: 'BMW X5 before detailing — dirty exterior',
//     afterAlt: 'BMW X5 after Elite Signature detail — showroom shine',
//     caption: 'BMW X5 · Plano · Elite Signature',
//     href: '/images/work/after-bmw-x5.jpg',
//   },
// ];
---

<Section id="work">
  <Container>
    <SectionHeader
      eyebrow="Results"
      title="Showcase Transformations"
      description="This gallery is ready for your before-and-after highlights. Add your best local jobs here to build a stronger premium results story."
      descriptionWidth="md"
    />

    <!--
      OWNER: Once you supply before/after photos to public/images/work/, replace the
      placeholder grid below with real <BeforeAfterSlider> components.
      Uncomment the example below as a template:

      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div data-reveal data-reveal-index="2">
          <BeforeAfterSlider
            client:visible
            before="/images/work/before-bmw-x5.jpg"
            after="/images/work/after-bmw-x5.jpg"
            beforeAlt="BMW X5 before detailing"
            afterAlt="BMW X5 after Elite Signature detail"
            caption="BMW X5 · Plano · Elite Signature"
          />
        </div>
      </div>
    -->

    <!-- Placeholder grid (shown until real photos arrive) — cinematic shimmer tiles.
         2-col on mobile: six full-width placeholder tiles would be ~2700px of scrolling. -->
    <div class="mt-10 grid grid-cols-2 gap-3 sm:gap-5 lg:grid-cols-3">
      {
        Array.from({ length: placeholderCount }, (_, i) => (
          <div
            data-reveal
            data-reveal-index={i + 2}
            class="tile-shimmer relative aspect-[4/3] overflow-hidden rounded-2xl border border-border"
            style={`--shimmer-delay: ${i * 0.35}s;`}
          >
            {/* Diagonal elevated wash + one corner glow — reads as a "slot", not a bug */}
            <div
              class="absolute inset-0"
              style="background: linear-gradient(135deg, var(--color-bg-elevated), var(--color-bg-elevated-2) 60%, var(--color-bg-elevated));"
              aria-hidden="true"
            />
            <div
              class="pointer-events-none absolute -top-12 -right-12 h-40 w-40 rounded-full"
              style="background: radial-gradient(closest-side, var(--color-brand-aurora), transparent 70%);"
              aria-hidden="true"
            />
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 p-4 text-center text-text-muted">
              <svg
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                class="opacity-40"
              >
                <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z" />
                <circle cx="12" cy="13" r="3" />
              </svg>
              <span
                class="rounded-full border px-3 py-1 text-xs font-medium"
                style="border-color: var(--color-border-hairline);"
              >
                Coming soon
              </span>
            </div>
          </div>
        ))
      }
    </div>

    <!-- "Coming soon" note — remove once real photos are added.
         Instagram is only mentioned when a profile URL is configured (no dangling CTA). -->
    <p data-reveal data-reveal-index="8" class="mt-6 text-center text-sm text-text-muted">
      {
        SOCIAL.instagram ? (
          <Fragment>
            Photography coming soon —{' '}
            <a
              href={SOCIAL.instagram}
              rel="noopener"
              target="_blank"
              class="text-brand underline-offset-4 hover:underline"
            >
              follow us on Instagram
            </a>{' '}
            for sneak peeks.
          </Fragment>
        ) : (
          'Fresh photography from recent details is on its way.'
        )
      }
    </p>
  </Container>
</Section>
