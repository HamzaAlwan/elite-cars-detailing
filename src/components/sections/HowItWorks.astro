---
/**
 * P3-T5 — How It Works (3 steps).
 * Semantic <ol> list. Inline SVG icons (aria-hidden). Payment copy is premium-framed.
 * Trailing "Book Your Detail" CTA to capture convinced users before they scroll further.
 */
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { CTA } from '@/data/site';

const steps = [
  {
    number: '01',
    title: 'Pick Your Package & Vehicle Size',
    body: 'Choose from our Standard Reset, Elite Signature, or Ceramic Upgrade. Select your vehicle size for an instant price — no surprises.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polyline points="9 16 11 18 15 14"/></svg>`,
  },
  {
    number: '02',
    title: 'We Come to You',
    body: 'Our fully self-contained rig arrives at your DFW home or office at your scheduled time. No water hookup or power outlet needed from you.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
  },
  {
    number: '03',
    title: 'Inspect & Pay on Completion',
    body: 'Walk around your vehicle and approve the finish. Pay securely by card, contactless, or Apple Pay. Cash is also welcome.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
  },
];
---

<Section id="how-it-works">
  <Container>
    <SectionHeader
      eyebrow="Process"
      title="How Your Detail Day Works"
      description="Three streamlined steps from booking to final handoff, designed to fit cleanly into busy workdays."
      descriptionWidth="md"
    />

    <ol class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-3" role="list">
      {
        steps.map((step, i) => (
          <li data-reveal data-reveal-index={i + 2} class="surface-raised flex flex-col gap-4 p-6">
            <div class="flex items-start gap-3">
              <span class="shrink-0 text-xl font-bold text-brand tabular-nums">{step.number}</span>
              <div class="text-brand" set:html={step.icon} />
            </div>
            <div>
              <h3 class="font-semibold text-text">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">{step.body}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <!-- Trailing CTA — catches users convinced by the process explanation -->
    <div data-reveal data-reveal-index="5" class="mt-8 flex justify-center gap-3">
      <Button href="#book">{CTA.book}</Button>
      <Button href="#quote" variant="subtle">Need help choosing?</Button>
    </div>
  </Container>
</Section>
