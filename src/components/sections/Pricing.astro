---
import Badge from '@/components/ui/Badge.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import PricingEstimator from '@/components/islands/PricingEstimator.vue';
import { CTA } from '@/data/site';
import { PRICING } from '@/data/pricing';

const tiers = [
  {
    id: 'standard-reset',
    name: 'The Standard Reset',
    price: `$${PRICING['standard-reset'].sedan}`,
    features: [
      'Hand wash & gloss protection',
      'Tire dressing & wheel face clean',
      'Interior vacuum & dash wipe-down',
    ],
    cta: CTA.book,
    ctaHref: '#book?package=standard-reset',
    ctaVariant: 'ghost' as const,
    featured: false,
  },
  {
    id: 'elite-signature',
    name: 'The Elite Signature',
    price: `$${PRICING['elite-signature'].sedan}`,
    features: [
      'Everything in Standard Reset',
      'Clay bar & iron decontamination',
      'Interior steam sanitization',
      'Leather clean & condition',
      'Protective wax coating',
    ],
    cta: CTA.book,
    ctaHref: '#book?package=elite-signature',
    ctaVariant: 'primary' as const,
    featured: true,
  },
  {
    id: 'ceramic-upgrade',
    name: 'The Ceramic Showroom Upgrade',
    price: 'From $650',
    features: [
      '3-year ceramic coating from $650',
      '9-year coating from ~$1,500',
      'Full surface prep & polish included',
      'Exact quote after vehicle inspection',
    ],
    cta: CTA.quote,
    ctaHref: '#quote',
    ctaVariant: 'ghost' as const,
    featured: false,
  },
];
---

<Section id="pricing">
  <Container>
    <h2 data-reveal data-reveal-index="0">Our Packages</h2>
    <p data-reveal data-reveal-index="1" class="mt-3 max-w-2xl text-text-muted">
      Transparent pricing — no hidden fees. Select your vehicle size to see the exact price.
    </p>

    <!-- Vehicle size selector -->
    <div class="mt-6" data-reveal data-reveal-index="2">
      <PricingEstimator client:visible />
    </div>

    <!-- Pricing tier cards -->
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {tiers.map((tier, i) => (
        <div
          data-reveal
          data-reveal-index={i + 3}
          class:list={[
            'card-hover relative flex flex-col overflow-hidden rounded-2xl',
            tier.featured ? 'surface-featured' : 'surface-raised',
          ]}
        >
          {/* Top brand accent bar on featured card */}
          {tier.featured && (
            <div class="absolute inset-x-0 top-0 h-0.5 bg-brand" aria-hidden="true" />
          )}

          <div class="flex flex-col grow p-6">
            {/* Badge — inside card flow, not absolute */}
            {tier.featured && (
              <span class="mb-4 self-start">
                <Badge class="badge-featured gap-1.5 text-xs">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3l1.88 5.76a2 2 0 0 0 1.26 1.26L21 12l-5.76 1.88a2 2 0 0 0-1.26 1.26L12 21l-1.88-5.76a2 2 0 0 0-1.26-1.26L3 12l5.76-1.88a2 2 0 0 0 1.26-1.26L12 3z"/>
                  </svg>
                  Most Popular
                </Badge>
              </span>
            )}

            <h3 class="font-semibold text-text">{tier.name}</h3>

            <p class="mt-3 flex items-baseline gap-1.5">
              <span data-price={tier.id} class="text-3xl font-bold tracking-tight text-text">{tier.price}</span>
              <span class="text-sm text-text-muted">/ sedan</span>
            </p>

            <ul class="mt-5 grow space-y-2.5">
              {tier.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-text-muted">
                  <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    class="mt-0.5 shrink-0 text-success"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              data-cta={tier.id}
              href={tier.ctaHref}
              class:list={[
                'mt-7 inline-flex min-h-11 w-full cursor-pointer items-center justify-center gap-2 rounded-full px-6 font-medium tracking-tight',
                tier.ctaVariant === 'primary'
                  ? 'btn-metal'
                  : 'border border-border text-text transition-colors hover:border-border-bright',
              ]}
            >
              {tier.cta}
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Add-ons note -->
    <p data-reveal data-reveal-index="6" class="mt-6 text-sm text-text-muted">
      Add extras at checkout: <strong class="text-text">Pet Hair Removal ($50)</strong> · <strong class="text-text">Odor Elimination ($60)</strong>
    </p>

    <!-- Satisfaction guarantee -->
    <p data-reveal data-reveal-index="7" class="mt-4 flex items-center gap-2 text-sm text-text-muted">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        <polyline points="9 12 11 14 15 10"/>
      </svg>
      100% satisfaction guaranteed — not happy? We come back, no charge.
    </p>
  </Container>
</Section>
