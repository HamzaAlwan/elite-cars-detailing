---
/**
 * P3-T7 — Service area (static shell).
 * City pill badges in a flex-wrap row (not a dot-separated string).
 * Mount point for Phase 4 zip validator island (P4-T3).
 */
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import ZipValidator from '@/components/islands/ZipValidator.vue';
import { SERVICE_AREA_CITIES } from '@/data/site';
---

<Section id="service-area">
  <Container>
    <h2 data-reveal data-reveal-index="0">Serving Richardson &amp; the DFW Metro</h2>
    <p data-reveal data-reveal-index="1" class="mt-3 max-w-2xl text-text-muted">
      We cover a 50-mile radius from our Richardson, TX base — from Frisco down to Irving, and
      everywhere between.
    </p>

    <!-- City pill chips -->
    <ul
      data-reveal
      data-reveal-index="2"
      class="mt-8 flex flex-wrap gap-2"
      aria-label="Cities we serve"
    >
      {
        SERVICE_AREA_CITIES.map((city) => (
          <li>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-bg-elevated px-4 py-1.5 text-sm text-text-muted">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              {city}
            </span>
          </li>
        ))
      }
    </ul>

    <!-- Zip validator island (P4-T3, client:visible) -->
    <div data-reveal data-reveal-index="3" class="mt-8 max-w-sm">
      <p class="mb-3 text-sm font-medium text-text">Not sure if we cover your area?</p>
      <ZipValidator client:visible />
    </div>
  </Container>
</Section>
