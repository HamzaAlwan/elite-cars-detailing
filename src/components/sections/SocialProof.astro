---
/**
 * P3-T6 — Social proof (cold-start).
 * NO fabricated review cards. Uses genuine credibility:
 * - 100% Satisfaction Guarantee callout
 * - Certified / Insured / DFW-Based credentials
 * - Brand product logos (real brands we use)
 * - Placeholder comment marks where real Google review cards will slot in
 */
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';

const credentials = [
  { label: 'Certified Technicians' },
  { label: 'Fully Insured' },
  { label: 'DFW-Based & Owner-Operated' },
  { label: '50-Mile Service Radius' },
];

// Real brands we use. Drop an official SVG into public/logos/ and set `logo` to render it as a
// real logo; until then a styled wordmark ships. (CQUARTZ folded into CarPro — it's a CarPro line.)
const products: { name: string; note: string; logo?: string }[] = [
  { name: "Meguiar's", note: 'Wash & clay' },
  { name: 'CarPro', note: 'Decon & ceramic' },
  { name: 'Gyeon', note: 'Ceramic coatings' },
];
---

<Section id="social-proof" atmosphere="subtle">
  <Container>
    <SectionHeader
      eyebrow="Confidence"
      title="Built on Process, Not Hype"
      description="No inflated claims. We focus on repeatable quality standards, insured technicians, and products trusted by professional detailers."
      descriptionWidth="md"
    />

    <!-- Guarantee callout -->
    <div
      data-reveal
      data-reveal-index="2"
      class="surface-featured mt-10 flex flex-col gap-4 p-8 sm:flex-row sm:items-center sm:gap-8"
    >
      <div class="shadow-glow-sm bg-brand-tint shrink-0 self-start rounded-full p-3 text-brand sm:self-center">
        <svg
          width="48"
          height="48"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          <polyline points="9 12 11 14 15 10"></polyline>
        </svg>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-text">100% Satisfaction Guaranteed</h3>
        <p class="mt-1 text-text-muted">
          Not completely satisfied with the result? We'll return and re-detail the affected areas at
          no extra charge. Your satisfaction is non-negotiable.
        </p>
      </div>
    </div>

    <!-- Credentials -->
    <ul data-reveal data-reveal-index="3" class="mt-8 flex flex-wrap gap-3">
      {
        credentials.map((c) => (
          <li class="flex items-center gap-2 rounded-full border border-border bg-bg-elevated px-4 py-2 text-sm text-text-muted">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {c.label}
          </li>
        ))
      }
    </ul>

    <!-- Product brands — monochrome→color logo strip (Phase 6) -->
    <div data-reveal data-reveal-index="4" class="mt-10">
      <p class="text-sm font-medium tracking-widest text-text-muted uppercase">
        Professional Products We Use
      </p>
      <ul class="mt-4 flex flex-wrap gap-3">
        {
          products.map((p) => (
            <li class="logo-tile card-hover flex min-h-16 min-w-[140px] flex-1 flex-col items-center justify-center gap-1 rounded-2xl border border-border bg-bg-elevated px-6 py-4 text-center sm:flex-none">
              {p.logo ? (
                <img
                  src={p.logo}
                  alt={`${p.name} logo`}
                  width="120"
                  height="32"
                  loading="lazy"
                  class="logo-mono h-8 w-auto object-contain"
                />
              ) : (
                <span class="logo-mono text-lg font-bold tracking-tight text-text">{p.name}</span>
              )}
              <span class="text-xs text-text-muted">{p.note}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <!--
      REVIEW CARDS PLACEHOLDER
      Add real Google review cards here once genuine GBP reviews exist (P7-T7, AggregateRating).
      Pattern: <figure class="surface-raised p-6"><blockquote>…</blockquote><figcaption>Name · City · Vehicle</figcaption></figure>
    -->
  </Container>
</Section>
