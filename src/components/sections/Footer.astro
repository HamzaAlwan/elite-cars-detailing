---
/**
 * P3-T8 — Site footer.
 * - logo-compact.svg wordmark + tagline
 * - Multi-column layout on desktop
 * - <address> wrapping NAP (accessibility + schema)
 * - Tap-to-call + mailto links with cursor-pointer
 * - Dynamic copyright year
 * - Cookieless analytics note (Umami — no consent banner needed)
 */
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
import { SITE, CONTACT, SERVICE_AREA_CITIES } from '@/data/site';
import { hasConfiguredEmail, hasConfiguredPhone } from '@/lib/contact';

const year = new Date().getFullYear();

const navLinks = [
  { href: '#value', label: 'Services' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#how-it-works', label: 'How It Works' },
  { href: '#work', label: 'Our Work' },
  { href: '#service-area', label: 'Service Area' },
  { href: '#faq', label: 'FAQ' },
  { href: '#book', label: 'Book Now' },
  { href: '#quote', label: 'Get a Quote' },
];
---

<footer class="border-t border-border bg-bg-elevated">
  <Container class="py-12 md:py-16">
    <section class="surface-raised mb-10 p-6 md:p-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="text-xs font-semibold tracking-[0.16em] text-text-muted uppercase">
            Ready When You Are
          </p>
          <h3 class="mt-2 text-2xl font-semibold text-text">Book your detail in under a minute.</h3>
          <p class="mt-2 max-w-2xl text-sm text-text-muted">
            Choose your package, pick your slot, and we come to your driveway with a fully
            self-contained setup.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <Button href="#book" class="min-h-10 px-5 text-sm">Book Your Detail</Button>
          {
            hasConfiguredPhone(CONTACT.phoneE164) ? (
              <a
                href={`tel:${CONTACT.phoneE164}`}
                class="btn-secondary inline-flex min-h-10 items-center justify-center rounded-full px-5 text-sm font-medium"
                aria-label={`Call us at ${CONTACT.phoneDisplay}`}
              >
                {CONTACT.phoneDisplay}
              </a>
            ) : (
              <Button href="#quote" variant="secondary" class="min-h-10 px-5 text-sm">
                Get a Free Quote
              </Button>
            )
          }
        </div>
      </div>
    </section>

    <div class="grid grid-cols-1 gap-10 md:grid-cols-4">
      <!-- Brand column -->
      <div class="md:col-span-2">
        <a href="#" aria-label="Elite Mobile Car Detailing — back to top" class="inline-block">
          <img
            src="/logo-compact.png"
            alt="Elite Mobile Car Detailing"
            width="180"
            height="36"
            loading="lazy"
            decoding="async"
            class="h-10 w-auto"
          />
        </a>
        <p class="mt-3 text-sm text-text-muted italic">{SITE.tagline}</p>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-text-muted">
          Premium mobile car detailing serving Richardson and the DFW metro. 100% self-contained —
          we bring our own water and power.
        </p>

        <!-- NAP in <address> for schema and accessibility -->
        <address class="mt-5 space-y-1 text-sm text-text-muted not-italic">
          {
            hasConfiguredPhone(CONTACT.phoneE164) ? (
              <p>
                <a
                  href={`tel:${CONTACT.phoneE164}`}
                  class="cursor-pointer transition-colors hover:text-text"
                  aria-label={`Call us at ${CONTACT.phoneDisplay}`}
                >
                  {CONTACT.phoneDisplay}
                </a>
              </p>
            ) : null
          }
          {
            hasConfiguredEmail(CONTACT.email) ? (
              <p>
                <a
                  href={`mailto:${CONTACT.email}`}
                  class="cursor-pointer transition-colors hover:text-text"
                >
                  {CONTACT.email}
                </a>
              </p>
            ) : null
          }
          <p>Richardson, TX 75080</p>
          <p>{CONTACT.hours}</p>
        </address>
      </div>

      <!-- Navigation column -->
      <div>
        <p class="text-xs font-semibold tracking-widest text-text-muted uppercase">Navigate</p>
        <nav aria-label="Footer navigation" class="mt-4">
          <ul class="space-y-2">
            {
              navLinks.map(({ href, label }) => (
                <li>
                  <a href={href} class="text-sm text-text-muted transition-colors hover:text-text">
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>

      <!-- Service area column -->
      <div>
        <p class="text-xs font-semibold tracking-widest text-text-muted uppercase">
          Areas We Serve
        </p>
        <ul class="mt-4 flex flex-wrap gap-2">
          {SERVICE_AREA_CITIES.map((city) => (
            <li class="rounded-full border border-border bg-bg px-3 py-1 text-xs text-text-muted">
              {city}, TX
            </li>
          ))}
        </ul>
        <p class="mt-4 text-xs text-text-muted">Plus nearby DFW neighborhoods within our service radius.</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-10 flex flex-col items-start justify-between gap-4 border-t border-border pt-6 sm:flex-row sm:items-center"
    >
      <p class="text-xs text-text-muted">
        &copy; {year}{' '}{SITE.name} &middot; Richardson, TX
      </p>
      <p class="text-xs text-text-muted">This site uses no tracking cookies.</p>
    </div>
  </Container>
</footer>
