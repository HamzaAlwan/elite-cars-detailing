---
/**
 * P3-T8 — Site footer.
 * - logo-compact.svg wordmark + tagline
 * - Multi-column layout on desktop
 * - <address> wrapping NAP (accessibility + schema)
 * - Tap-to-call + mailto links with cursor-pointer
 * - Dynamic copyright year
 * - Cookieless analytics note (Umami — no consent banner needed)
 */
import Container from '@/components/ui/Container.astro';
import { SITE, CONTACT, SERVICE_AREA_CITIES } from '@/data/site';

const year = new Date().getFullYear();

const navLinks = [
  { href: '#value', label: 'Services' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#work', label: 'Our Work' },
  { href: '#how-it-works', label: 'How It Works' },
  { href: '#service-area', label: 'Service Area' },
  { href: '#faq', label: 'FAQ' },
  { href: '#book', label: 'Book Now' },
  { href: '#quote', label: 'Get a Quote' },
];
---

<footer class="border-t border-border bg-bg-elevated">
  <Container class="py-12 md:py-16">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-4">

      <!-- Brand column -->
      <div class="md:col-span-2">
        <a href="#" aria-label="Elite Mobile Car Detailing — back to top" class="inline-block">
          <img
            src="/logo-compact.png"
            alt="Elite Mobile Car Detailing"
            width="180"
            height="36"
            class="h-9 w-auto"
          />
        </a>
        <p class="mt-3 text-sm italic text-text-muted">{SITE.tagline}</p>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-text-muted">
          Premium mobile car detailing serving Richardson and the DFW metro.
          100% self-contained — we bring our own water and power.
        </p>

        <!-- NAP in <address> for schema and accessibility -->
        <address class="mt-5 space-y-1 not-italic text-sm text-text-muted">
          {CONTACT.phoneE164 && CONTACT.phoneE164 !== '{{PHONE_E164}}' ? (
            <p>
              <a
                href={`tel:${CONTACT.phoneE164}`}
                class="cursor-pointer transition-colors hover:text-text"
                aria-label={`Call us at ${CONTACT.phoneDisplay}`}
              >
                {CONTACT.phoneDisplay}
              </a>
            </p>
          ) : null}
          {CONTACT.email && CONTACT.email !== '{{EMAIL}}' ? (
            <p>
              <a
                href={`mailto:${CONTACT.email}`}
                class="cursor-pointer transition-colors hover:text-text"
              >
                {CONTACT.email}
              </a>
            </p>
          ) : null}
          <p>Richardson, TX 75080</p>
          <p>{CONTACT.hours}</p>
        </address>
      </div>

      <!-- Navigation column -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-text-muted">Navigate</p>
        <nav aria-label="Footer navigation" class="mt-4">
          <ul class="space-y-2">
            {navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-text-muted transition-colors hover:text-text"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Service area column -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-text-muted">Areas We Serve</p>
        <ul class="mt-4 space-y-2">
          {SERVICE_AREA_CITIES.map((city) => (
            <li class="text-sm text-text-muted">{city}, TX</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 flex flex-col items-start justify-between gap-4 border-t border-border pt-6 sm:flex-row sm:items-center">
      <p class="text-xs text-text-muted">
        &copy; {year} {SITE.name} &middot; Richardson, TX
      </p>
      <p class="text-xs text-text-muted">
        This site uses no tracking cookies.
      </p>
    </div>
  </Container>
</footer>
