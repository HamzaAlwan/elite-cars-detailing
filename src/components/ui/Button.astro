---
/**
 * Static CTA primitive (zero JS). Renders <a> when `href` is set, else <button>.
 * variant="primary" → matte sapphire CTA (.btn-metal); "ghost" → outline.
 * Always ≥44px tall (touch target). Interactive logic lives in islands, not here.
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'subtle';
  type?: 'button' | 'submit';
  class?: string;
}
const { href, variant = 'primary', type = 'button', class: className = '' } = Astro.props;

const base =
  'inline-flex min-h-11 cursor-pointer items-center justify-center gap-2 rounded-full px-6 font-medium tracking-tight';
const variants = {
  primary: 'btn-metal',
  secondary: 'btn-secondary',
  ghost: 'border border-border text-text transition-colors hover:border-border-bright',
  subtle: 'btn-subtle',
} as const;
const classes = [base, variants[variant], className];
---

{
  href ? (
    <a href={href} class:list={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class:list={classes}>
      <slot />
    </button>
  )
}
