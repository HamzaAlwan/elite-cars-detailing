---
import '@/styles/global.css';
import '@fontsource-variable/outfit';
import { ClientRouter } from 'astro:transitions';
import { SITE } from '@/data/site';
import Seo from '@/components/Seo.astro';

interface Props {
  /** Page <title>; falls back to "Name — Tagline". */
  title?: string;
  description?: string;
  /** OG image path (relative to root). */
  ogImage?: string;
  /** Keep the page out of search indexes (e.g. the internal /preview showcase). */
  noindex?: boolean;
}

const { title, description, ogImage, noindex = false } = Astro.props;
// Callers pass the complete <title> string; fall back to brand + tagline when omitted.
const pageTitle = title ?? `${SITE.name} — ${SITE.tagline}`;

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#06080F" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />
    <Seo title={pageTitle} description={description} ogImage={ogImage}>
      <slot name="jsonld" />
    </Seo>
    <ClientRouter />
    <slot name="head" />
  </head>
  <!-- pb-[72px] reserves space for the sticky mobile action bar (StickyBar.astro).
       md:pb-0 removes it on desktop where the bar is hidden. -->
  <body class="min-h-svh pb-[72px] md:pb-0">
    <a
      href="#main"
      class="sr-only rounded-md bg-text px-4 py-2 font-medium text-bg focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50"
    >
      Skip to content
    </a>
    <slot name="header" />
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
