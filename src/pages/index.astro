---
/**
 * Homepage — single page, all anchored sections.
 * Section order (spec §4): Nav → Hero → Value → Pricing → How It Works →
 *   [Our Work gallery — Phase 5] → Social Proof → Service Area →
 *   [Booking — Phase 6] → FAQ → Footer + Sticky Bar
 *
 * Phases 4-6 leave mount-point placeholders so anchor links work from day one.
 */
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/sections/Nav.astro';
import Hero from '@/components/sections/Hero.astro';
import ValueProps from '@/components/sections/ValueProps.astro';
import Pricing from '@/components/sections/Pricing.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import SocialProof from '@/components/sections/SocialProof.astro';
import ServiceArea from '@/components/sections/ServiceArea.astro';
import OurWork from '@/components/sections/OurWork.astro';
import Footer from '@/components/sections/Footer.astro';
import StickyBar from '@/components/sections/StickyBar.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import QuoteForm from '@/components/islands/QuoteForm.vue';
import FaqAccordion from '@/components/islands/FaqAccordion.vue';
import { CONTACT } from '@/data/site';
import {
  buildLocalBusinessSchema,
  buildFAQSchema,
  buildOrganizationSchema,
  buildWebSiteSchema,
} from '@/data/schema';

const title = 'Elite Mobile Car Detailing | Richardson & DFW Metro';
const description =
  'Premium mobile car detailing in Richardson, TX and the DFW metro. 100% self-contained — we bring our own water and power. Same-day slots. Book online or get a free quote.';

const jsonLd = [
  buildLocalBusinessSchema(),
  buildFAQSchema(),
  buildOrganizationSchema(),
  buildWebSiteSchema(),
];
---

<Layout title={title} description={description}>
  <Fragment slot="jsonld">
    {
      jsonLd.map((schema) => (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
      ))
    }
  </Fragment>
  <Nav slot="header" />

  <!-- Hero — single h1 for the page lives here -->
  <Hero />

  <hr class="divider-chrome" />

  <!-- Value props -->
  <ValueProps />

  <hr class="divider-chrome" />

  <!-- Pricing -->
  <Pricing />

  <hr class="divider-chrome" />

  <!-- How It Works -->
  <HowItWorks />

  <hr class="divider-chrome" />

  <!-- Our Work gallery (Phase 5) -->
  <OurWork />

  <hr class="divider-chrome" />

  <!-- Social Proof -->
  <SocialProof />

  <hr class="divider-chrome" />

  <!-- Service Area -->
  <ServiceArea />

  <hr class="divider-chrome" />

  <!-- Booking — Cal.com embed (P6-T2) -->
  <Section id="book">
    <Container>
      <h2 data-reveal data-reveal-index="0">Book Your Detail</h2>
      <p data-reveal data-reveal-index="1" class="mt-3 max-w-2xl text-text-muted">
        Pick a day and time that works for you — we come to your DFW home or office. No card
        required up front; pay only after you're satisfied.
      </p>
      <p data-reveal data-reveal-index="2" class="mt-2 text-sm text-text-muted">
        Prefer to talk? Call us at
        {
          CONTACT.phoneE164 !== '{{PHONE_E164}}' ? (
            <a href={`tel:${CONTACT.phoneE164}`} class="text-brand hover:underline">
              {CONTACT.phoneDisplay}
            </a>
          ) : (
            <span class="text-text-muted">the number in the footer</span>
          )
        }.
      </p>
      <div data-reveal data-reveal-index="3" class="mt-8 flex flex-wrap items-center gap-4">
        <!-- Opens the global BookingModal (Phase 4). href keeps a no-JS fallback (scrolls here). -->
        <a
          href="#book"
          class="btn-metal inline-flex min-h-12 cursor-pointer items-center gap-2 rounded-full px-8 text-base font-medium"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          Pick a day &amp; time
        </a>
      </div>
    </Container>
  </Section>

  <!-- Quote form — Web3Forms (P6-T3) -->
  <Section id="quote">
    <Container>
      <h2 data-reveal data-reveal-index="0">Get a Free Quote</h2>
      <p data-reveal data-reveal-index="1" class="mt-3 max-w-xl text-text-muted">
        Not ready to book yet? Tell us about your vehicle and we'll call or text you back within a
        few hours.
      </p>
      <div
        data-reveal
        data-reveal-index="2"
        class="mt-10 grid gap-8 lg:grid-cols-[1fr_minmax(0,28rem)] lg:items-start lg:gap-12"
      >
        <div class="flex flex-col gap-5">
          <ul class="space-y-4 text-sm text-text-muted">
            <li class="flex gap-3">
              <svg
                class="mt-0.5 shrink-0 text-brand"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"
                ></polyline>
              </svg>
              <span>We respond within a few hours — usually the same day.</span>
            </li>
            <li class="flex gap-3">
              <svg
                class="mt-0.5 shrink-0 text-brand"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line
                  x1="1"
                  y1="10"
                  x2="23"
                  y2="10"></line>
              </svg>
              <span>No card required upfront — just your contact info and vehicle details.</span>
            </li>
            <li class="flex gap-3">
              <svg
                class="mt-0.5 shrink-0 text-brand"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
              <span>Certified technicians, fully insured, DFW-based &amp; owner-operated.</span>
            </li>
          </ul>
          {
            CONTACT.phoneE164 !== '{{PHONE_E164}}' && (
              <p class="text-sm text-text-muted">
                Prefer to talk now?{' '}
                <a
                  href={`tel:${CONTACT.phoneE164}`}
                  class="font-medium text-text underline-offset-2 hover:underline"
                >
                  {CONTACT.phoneDisplay}
                </a>
              </p>
            )
          }
        </div>
        <div class="surface-raised p-6 md:p-8">
          <QuoteForm client:visible />
        </div>
      </div>
    </Container>
  </Section>

  <hr class="divider-chrome" />

  <!-- FAQ — animated Reka accordion (Phase 3); content + JSON-LD share src/data/faq.ts -->
  <Section id="faq">
    <Container>
      <h2 data-reveal data-reveal-index="0">Frequently Asked Questions</h2>
      <div data-reveal data-reveal-index="1" class="mt-6">
        <FaqAccordion client:visible />
      </div>
    </Container>
  </Section>

  <Footer slot="footer" />
  <StickyBar slot="footer" />
</Layout>

<script>
  import { initReveal } from '@/lib/reveal';
  initReveal();
</script>
