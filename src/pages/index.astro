---
/**
 * Homepage — single page, all anchored sections.
 * Section order (spec §4): Nav → Hero → Value → Pricing → How It Works →
 *   [Our Work gallery — Phase 5] → Social Proof → Service Area →
 *   [Booking — Phase 6] → FAQ → Footer + Sticky Bar
 *
 * Phases 4-6 leave mount-point placeholders so anchor links work from day one.
 */
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/sections/Nav.astro';
import Hero from '@/components/sections/Hero.astro';
import ValueProps from '@/components/sections/ValueProps.astro';
import Pricing from '@/components/sections/Pricing.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';
import SocialProof from '@/components/sections/SocialProof.astro';
import ServiceArea from '@/components/sections/ServiceArea.astro';
import OurWork from '@/components/sections/OurWork.astro';
import Footer from '@/components/sections/Footer.astro';
import StickyBar from '@/components/sections/StickyBar.astro';
import Section from '@/components/ui/Section.astro';
import Container from '@/components/ui/Container.astro';
import BookingEmbed from '@/components/islands/BookingEmbed.vue';
import QuoteForm from '@/components/islands/QuoteForm.vue';
import { CONTACT } from '@/data/site';
import {
  buildLocalBusinessSchema,
  buildFAQSchema,
  buildOrganizationSchema,
  buildWebSiteSchema,
} from '@/data/schema';

const title = 'Elite Mobile Car Detailing | Richardson & DFW Metro';
const description =
  'Premium mobile car detailing in Richardson, TX and the DFW metro. 100% self-contained — we bring our own water and power. Same-day slots. Book online or get a free quote.';

const jsonLd = [
  buildLocalBusinessSchema(),
  buildFAQSchema(),
  buildOrganizationSchema(),
  buildWebSiteSchema(),
];
---

<Layout title={title} description={description}>
  <Fragment slot="jsonld">
    {jsonLd.map((schema) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>
  <Nav slot="header" />

  <!-- Hero — single h1 for the page lives here -->
  <Hero />

  <hr class="divider-chrome" />

  <!-- Value props -->
  <ValueProps />

  <hr class="divider-chrome" />

  <!-- Pricing -->
  <Pricing />

  <hr class="divider-chrome" />

  <!-- How It Works -->
  <HowItWorks />

  <hr class="divider-chrome" />

  <!-- Our Work gallery (Phase 5) -->
  <OurWork />

  <hr class="divider-chrome" />

  <!-- Social Proof -->
  <SocialProof />

  <hr class="divider-chrome" />

  <!-- Service Area -->
  <ServiceArea />

  <hr class="divider-chrome" />

  <!-- Booking — Cal.com embed (P6-T2) -->
  <Section id="book">
    <Container>
      <h2 data-reveal data-reveal-index="0">Book Your Detail</h2>
      <p data-reveal data-reveal-index="1" class="mt-3 max-w-2xl text-text-muted">
        Pick a day and time that works for you — we come to your DFW home or office. No card required up front; pay only after you're satisfied.
      </p>
      <p data-reveal data-reveal-index="2" class="mt-2 text-sm text-text-muted">
        Prefer to talk? Call us at
        {CONTACT.phoneE164 !== '{{PHONE_E164}}' ? (
          <a href={`tel:${CONTACT.phoneE164}`} class="text-brand hover:underline">{CONTACT.phoneDisplay}</a>
        ) : (
          <span class="text-text-muted">the number in the footer</span>
        )}.
      </p>
      <div data-reveal data-reveal-index="3" class="mt-8 max-w-2xl">
        <BookingEmbed client:visible />
      </div>
    </Container>
  </Section>

  <!-- Quote form — Web3Forms (P6-T3) -->
  <Section id="quote">
    <Container>
      <h2 data-reveal data-reveal-index="0">Get a Free Quote</h2>
      <p data-reveal data-reveal-index="1" class="mt-3 max-w-xl text-text-muted">
        Not ready to book yet? Tell us about your vehicle and we'll call or text you back within a few hours.
      </p>
      <div data-reveal data-reveal-index="2" class="mt-8 max-w-md">
        <QuoteForm client:visible />
      </div>
    </Container>
  </Section>

  <hr class="divider-chrome" />

  <!-- FAQ — static <details> (Phase 4 island can upgrade accordion; P4-T4) -->
  <Section id="faq">
    <Container>
      <h2 data-reveal data-reveal-index="0">Frequently Asked Questions</h2>
      <div data-reveal data-reveal-index="1" class="mt-6 space-y-3">
        {[
          {
            id: 'faq-hookups',
            q: 'Do you need access to my water or power?',
            a: 'No — our rigs are fully self-contained with onboard water tanks and a generator. We can detail anywhere, including apartment complexes and office lots with no utility access.',
          },
          {
            id: 'faq-time',
            q: 'How long does a detail take?',
            a: 'The Standard Reset takes 2–3 hours. The Elite Signature runs 4–5 hours. Ceramic coatings require a full day (8+ hours) including prep, coating, and cure time.',
          },
          {
            id: 'faq-weather',
            q: 'What if the weather is bad?',
            a: "Texas weather shifts fast. If conditions aren't right on your scheduled day, we'll contact you to reschedule at no fee — your booking stays secure.",
          },
          {
            id: 'faq-payment',
            q: 'How do I pay?',
            a: "We accept card, contactless, and Apple Pay on completion. Cash is also welcome. No payment is required until you've inspected the result and are satisfied.",
          },
          {
            id: 'faq-area',
            q: 'Do you serve my area?',
            a: 'We cover a 50-mile radius from Richardson, TX — including Dallas, Plano, Frisco, McKinney, Allen, Garland, Carrollton, and Irving. Use the ZIP checker above to confirm.',
          },
        ].map(({ id, q, a }) => (
          <details id={id} class="rounded-xl border border-border bg-bg-elevated">
            <summary class="cursor-pointer px-5 py-4 font-medium text-text marker:content-none">
              <span class="flex items-center justify-between gap-3">
                {q}
                <svg
                  class="shrink-0 text-text-muted transition-transform duration-[--dur-fast] [[open]_&]:rotate-180"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </span>
            </summary>
            <p class="px-5 pb-4 pt-1 text-sm leading-relaxed text-text-muted">{a}</p>
          </details>
        ))}
      </div>
    </Container>
  </Section>

  <Footer slot="footer" />
  <StickyBar slot="footer" />
</Layout>

<script>
  import { initReveal } from '@/lib/reveal';
  initReveal();
</script>
