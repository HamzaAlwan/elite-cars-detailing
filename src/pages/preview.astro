---
/**
 * /preview — internal design showcase & approval gate (Phase 2.5). noindex + sitemap-excluded.
 * Owner reviews this (ideally on a real iPhone) and picks variants before the Phase 3 build.
 * Remove before launch. Components here are reused by Phase 3.
 */
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import { SITE, CTA, SERVICE_AREA_CITIES } from '@/data/site';
import { ShieldCheck, Droplets, Clock, Sparkles, MapPin, CheckCircle2 } from '@lucide/vue';

const colorTokens = [
  { name: '--color-bg', hex: '#06080F', cls: 'bg-bg' },
  { name: '--color-bg-elevated', hex: '#0D1019', cls: 'bg-bg-elevated' },
  { name: '--color-bg-elevated-2', hex: '#151926', cls: 'bg-bg-elevated-2' },
  { name: '--color-border', hex: '#222838', cls: 'bg-border' },
  { name: '--color-border-bright', hex: '#39445C', cls: 'bg-border-bright' },
  { name: '--color-text', hex: '#F4F7FF', cls: 'bg-text' },
  { name: '--color-text-muted', hex: '#A4AEC4', cls: 'bg-text-muted' },
  { name: '--color-brand', hex: '#1E5FFF', cls: 'bg-brand' },
  { name: '--color-brand-strong', hex: '#1E5FFF', cls: 'bg-brand-strong' },
  { name: '--color-brand-deep', hex: '#1340A8', cls: 'bg-brand-deep' },
  { name: '--color-brand-bright', hex: '#5B8CFF', cls: 'bg-brand-bright' },
  { name: '--color-success', hex: '#22C55E', cls: 'bg-success' },
  { name: '--color-warning', hex: '#F59E0B', cls: 'bg-warning' },
];

const typeScale = [
  { tag: 'h1', label: 'Heading 1 · 32→56', cls: 'text-h1' },
  { tag: 'h2', label: 'Heading 2 · 26→40', cls: 'text-h2' },
  { tag: 'h3', label: 'Heading 3 · 20→24', cls: 'text-h3' },
  { tag: 'p', label: 'Body · 16 / 1.6', cls: 'text-base' },
  { tag: 'p', label: 'Small · 14', cls: 'text-sm text-text-muted' },
];

const motionTokens = [
  ['--ease-standard', 'default in-view UI'],
  ['--ease-out', 'entrances'],
  ['--ease-emphasized', 'signature settle (sweep)'],
  ['--ease-snappy', 'tap/press'],
  ['--dur-fast 150ms', 'hover/focus'],
  ['--dur-base 250ms', 'cards/accordion'],
  ['--dur-slow 350ms', 'reveals/drawer'],
  ['--dur-slower 500ms', 'hero / sweep (max)'],
];

const blueCandidates = [
  { label: 'A — Sapphire', hex: '#2B6BFF' },
  { label: 'B — Deep electric ✓ (chosen)', hex: '#1E5FFF' },
  { label: 'C — Brighter azure', hex: '#3B82F6' },
];

const valueProps = [
  { icon: Droplets, title: '100% Self-Contained', body: 'Onboard water + power — perfect for apartments and offices.' },
  { icon: ShieldCheck, title: 'Insured & Vetted', body: 'Certified, fully insured, 50-mile Richardson radius.' },
  { icon: Sparkles, title: 'Paint Protection', body: 'Decontamination, clay bar, multi-year ceramic coatings.' },
  { icon: Clock, title: 'Weather-Flexible', body: 'Texas weather shifts fast — reschedule in a tap.' },
];

const toc = [
  ['#foundations', 'Foundations'],
  ['#components', 'Components'],
  ['#sections', 'Sections'],
  ['#variations', 'Variations'],
  ['#states', 'States & motion'],
];
---

<Layout title="Design preview" noindex>
  <!-- Sticky TOC (also demos the glass nav) -->
  <nav class="nav-glass sticky top-0 z-40 border-b border-border">
    <Container class="flex flex-wrap items-center gap-x-5 gap-y-1 py-3 text-sm">
      <span class="font-semibold tracking-tight">/preview</span>
      {toc.map(([href, label]) => (
        <a href={href} class="text-text-muted hover:text-text">{label}</a>
      ))}
    </Container>
  </nav>

  <Section class="!pt-10">
    <Container>
      <Badge>Phase 2.5 · approval gate</Badge>
      <h1 class="mt-4">Design preview</h1>
      <p class="mt-3 max-w-2xl text-text-muted">
        The design system made visible — foundations, components, assembled sections, and
        variants to choose from. Review on a phone; pick a metallic intensity + blue below.
      </p>
    </Container>
  </Section>

  <!-- ============================ FOUNDATIONS ============================ -->
  <Section id="foundations" class="!py-12">
    <Container>
      <h2>Foundations</h2>

      <h3 class="mt-8">Color tokens</h3>
      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
        {colorTokens.map((t) => (
          <div class="overflow-hidden rounded-xl border border-border">
            <div class={`h-16 ${t.cls}`}></div>
            <div class="bg-bg-elevated p-3">
              <p class="font-medium">{t.name}</p>
              <p class="text-sm text-text-muted">{t.hex}</p>
            </div>
          </div>
        ))}
      </div>

      <h3 class="mt-12">Typography — Outfit</h3>
      <div class="mt-4 space-y-3">
        {typeScale.map((t) => (
          <div class="flex flex-col gap-1 border-b border-border pb-3 sm:flex-row sm:items-baseline sm:justify-between">
            <span class={t.cls}>Showroom shine, delivered</span>
            <span class="text-sm text-text-muted">{t.label}</span>
          </div>
        ))}
      </div>

      <h3 class="mt-12">Elevation & radius</h3>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-2xl bg-bg-elevated p-6 text-sm text-text-muted">bg-elevated</div>
        <div class="rounded-2xl bg-bg-elevated-2 p-6 text-sm text-text-muted">bg-elevated-2</div>
        <div class="surface-raised p-6 text-sm text-text-muted">.surface-raised (bevel)</div>
      </div>

      <h3 class="mt-12">Icons (Lucide) & motion tokens</h3>
      <div class="mt-4 flex flex-wrap gap-4 text-brand">
        <ShieldCheck size={28} /><Droplets size={28} /><Sparkles size={28} />
        <Clock size={28} /><MapPin size={28} /><CheckCircle2 size={28} />
      </div>
      <ul class="mt-6 grid grid-cols-1 gap-x-8 gap-y-1 text-sm text-text-muted sm:grid-cols-2">
        {motionTokens.map(([tok, use]) => (
          <li class="flex justify-between border-b border-border py-1">
            <code class="text-text">{tok}</code><span>{use}</span>
          </li>
        ))}
      </ul>
    </Container>
  </Section>

  <hr class="divider-chrome" />

  <!-- ============================ COMPONENTS ============================ -->
  <Section id="components" class="!py-12">
    <Container>
      <h2>Components</h2>

      <h3 class="mt-8">Actions</h3>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <Button href="#">{CTA.book}</Button>
        <Button href="#" variant="ghost">{CTA.quote}</Button>
        <a href="#" class="text-brand underline-offset-4 hover:underline">Text link</a>
      </div>

      <h3 class="mt-10">Containers</h3>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        <Card>
          <h4 class="font-semibold">Card · .surface-raised</h4>
          <p class="mt-2 text-sm text-text-muted">Layered elevation + subtle bevel. Matte.</p>
        </Card>
        <Card>
          <div class="flex items-center gap-2"><Sparkles size={18} class="text-brand" /><span class="font-semibold">With icon</span></div>
          <p class="mt-2 text-sm text-text-muted">Cards carry most content blocks.</p>
        </Card>
      </div>

      <h3 class="mt-10">Forms</h3>
      <div class="mt-4 grid max-w-md gap-3">
        <input type="text" placeholder="Your name" class="rounded-xl border border-border bg-bg-elevated px-4 py-3 text-text placeholder:text-text-muted" />
        <input type="tel" placeholder="ZIP code" class="rounded-xl border border-border bg-bg-elevated px-4 py-3 text-text placeholder:text-text-muted" />
        <p class="flex items-center gap-2 text-sm text-success"><CheckCircle2 size={16} /> You're in our DFW service zone</p>
        <p class="text-sm text-warning">Please enter a valid 5-digit ZIP.</p>
      </div>

      <h3 class="mt-10">Disclosure (FAQ)</h3>
      <details class="mt-4 rounded-xl border border-border bg-bg-elevated p-4">
        <summary class="cursor-pointer font-medium">Do you need access to my water or power?</summary>
        <p class="mt-2 text-sm text-text-muted">No — our rigs are fully self-contained with onboard water and a generator.</p>
      </details>

      <h3 class="mt-10">Feedback</h3>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <Badge>100% Self-Contained</Badge>
        <Badge><Sparkles size={14} /> Most Popular</Badge>
        <span class="rounded-lg bg-success/15 px-3 py-1 text-sm text-success">Success</span>
        <span class="rounded-lg bg-warning/15 px-3 py-1 text-sm text-warning">Warning</span>
      </div>
    </Container>
  </Section>

  <hr class="divider-chrome" />

  <!-- ============================ SECTIONS ============================ -->
  <Section id="sections" class="!py-12">
    <Container>
      <h2>Sections <span class="text-base font-normal text-text-muted">(assembled mockups · placeholder data)</span></h2>

      <!-- Hero mock -->
      <div class="relative mt-8 overflow-hidden rounded-2xl border border-border bg-bg-elevated p-8 md:p-12">
        <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full" style="background: radial-gradient(closest-side, rgba(30,95,255,.28), transparent);"></div>
        <div class="relative max-w-xl">
          <h2>Showroom Shine. Delivered to Your Driveway.</h2>
          <p class="mt-4 text-text-muted">{SITE.description}</p>
          <div class="mt-6 flex flex-wrap gap-3">
            <Button href="#">{CTA.book}</Button>
            <Button href="#" variant="ghost">{CTA.quote}</Button>
          </div>
          <p class="mt-5 text-sm text-text-muted">100% self-contained · Same-day slots · Insured & vetted</p>
        </div>
      </div>

      <!-- Value props -->
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {valueProps.map((v) => {
          const Icon = v.icon;
          return (
            <Card class="icon-hover-trigger">
              <Icon size={28} class="icon-hover text-brand" />
              <h4 class="mt-4 font-semibold">{v.title}</h4>
              <p class="mt-2 text-sm text-text-muted">{v.body}</p>
            </Card>
          );
        })}
      </div>

      <!-- Pricing tier (Most Popular) -->
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <Card>
          <h4 class="font-semibold">The Standard Reset</h4>
          <p class="mt-1 text-2xl font-bold">$125<span class="text-base font-normal text-text-muted"> · Sedan</span></p>
          <p class="mt-2 text-sm text-text-muted">Hand wash, gloss protection, interior deep vacuum.</p>
          <Button href="#" variant="ghost" class="mt-5 w-full">Book This Package</Button>
        </Card>
        <Card class="relative ring-1 ring-brand">
          <span class="absolute -top-3 left-6"><Badge class="btn-metal border-0"><Sparkles size={14} /> Most Popular</Badge></span>
          <h4 class="font-semibold">The Elite Signature</h4>
          <p class="mt-1 text-2xl font-bold">$225<span class="text-base font-normal text-text-muted"> · Sedan</span></p>
          <p class="mt-2 text-sm text-text-muted">Clay bar, iron decon, interior steam, leather condition.</p>
          <Button href="#" class="mt-5 w-full">Book This Package</Button>
        </Card>
      </div>

      <!-- Service area -->
      <div class="mt-6 rounded-2xl border border-border bg-bg-elevated p-6">
        <h4 class="font-semibold">Serving the DFW metro</h4>
        <p class="mt-2 text-sm text-text-muted">{SERVICE_AREA_CITIES.join(' · ')}</p>
      </div>

      <!-- Footer mock -->
      <footer class="mt-6 rounded-2xl border border-border p-6 text-sm text-text-muted">
        <p class="font-semibold text-text">{SITE.name}</p>
        <p class="mt-1">{SITE.tagline}</p>
        <p class="mt-3">© {SITE.name} · Richardson, TX</p>
      </footer>
    </Container>
  </Section>

  <hr class="divider-chrome" />

  <!-- ============================ VARIATIONS ============================ -->
  <Section id="variations" class="!py-12">
    <Container>
      <h2>Variations <span class="text-base font-normal text-text-muted">(pick a direction)</span></h2>

      <h3 class="mt-8">Metallic intensity</h3>
      <p class="mt-1 text-sm text-text-muted">Matte chosen (B) — A/C shown for reference. Anodized, never chrome.</p>
      <div class="mt-4 grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div>
          <button class="demo-cta demo-flat">{CTA.book}</button>
          <p class="mt-2 text-center text-sm text-text-muted">A · Flat</p>
        </div>
        <div>
          <button class="btn-metal demo-cta">{CTA.book}</button>
          <p class="mt-2 text-center text-sm text-text-muted">B · Matte ✓ (chosen)</p>
        </div>
        <div>
          <button class="demo-cta demo-glossy">{CTA.book}</button>
          <p class="mt-2 text-center text-sm text-text-muted">C · Glossier</p>
        </div>
      </div>

      <h3 class="mt-12">Premium-blue candidates</h3>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {blueCandidates.map((b) => (
          <div class="rounded-xl border border-border bg-bg-elevated p-4">
            <div class="h-12 rounded-lg" style={`background:${b.hex}`}></div>
            <button class="demo-cta mt-3" style={`background:${b.hex};color:#fff`}>{CTA.book}</button>
            <p class="mt-3 text-sm font-medium">{b.label}</p>
            <p class="text-sm text-text-muted">{b.hex}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <hr class="divider-chrome" />

  <!-- ============================ STATES & MOTION ============================ -->
  <Section id="states" class="!py-12">
    <Container>
      <h2>States & motion</h2>

      <h3 class="mt-8">Button states</h3>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <Button href="#">Hover / focus me</Button>
        <button class="btn-metal demo-cta opacity-50" disabled>Disabled</button>
        <span class="text-sm text-text-muted">(matte CTA — subtle lift on desktop hover; tap = press)</span>
      </div>

      <h3 class="mt-10">Animated icons (no library)</h3>
      <div class="mt-4 flex flex-wrap items-center gap-8">
        <div class="flex flex-col items-center gap-2">
          <button data-menu-toggle aria-label="Toggle menu" class="rounded-lg border border-border p-2 text-text">
            <svg class="menu-icon" data-open="false" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line data-bar="top" x1="4" y1="7" x2="20" y2="7"></line>
              <line data-bar="middle" x1="4" y1="12" x2="20" y2="12"></line>
              <line data-bar="bottom" x1="4" y1="17" x2="20" y2="17"></line>
            </svg>
          </button>
          <span class="text-sm text-text-muted">Hamburger ↔ X (tap)</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <svg class="icon-draw text-success" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path pathLength="1" d="M20 6 9 17l-5-5"></path>
          </svg>
          <button data-check-replay class="text-sm text-brand underline-offset-4 hover:underline">Replay check</button>
        </div>
      </div>

      <h3 class="mt-10">Scroll-reveal & reduced-motion</h3>
      <p class="mt-1 text-sm text-text-muted">Cards fade + rise on scroll (staggered). Enable “Reduce Motion” → they show instantly.</p>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {[0, 1, 2, 3, 4, 5].map((i) => (
          <div data-reveal data-reveal-index={i} class="surface-raised p-6 text-sm text-text-muted">Reveal #{i + 1}</div>
        ))}
      </div>

      <h3 class="mt-10">Loading / empty / error</h3>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-border bg-bg-elevated p-4">
          <div class="h-4 w-2/3 animate-pulse rounded bg-border"></div>
          <div class="mt-3 h-4 w-1/2 animate-pulse rounded bg-border"></div>
          <p class="mt-3 text-sm text-text-muted">Loading…</p>
        </div>
        <div class="rounded-xl border border-dashed border-border p-4 text-sm text-text-muted">Nothing here yet — empty state.</div>
        <div class="rounded-xl border border-warning/40 bg-warning/10 p-4 text-sm text-warning">Something went wrong — try again or call us.</div>
      </div>
    </Container>
  </Section>
</Layout>

<style>
  /* Demo-only CTA sizing + the A/C metallic variants (B uses the real .btn-metal). */
  .demo-cta {
    display: inline-flex;
    min-height: 2.75rem;
    width: 100%;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    padding-inline: 1.5rem;
    font-weight: 500;
    color: #fff;
  }
  .demo-flat {
    background: var(--color-brand-strong);
  }
  .demo-glossy {
    background-image:
      linear-gradient(180deg, rgb(255 255 255 / 0.4), rgb(255 255 255 / 0) 42%),
      linear-gradient(180deg, var(--color-brand-bright), var(--color-brand-strong) 52%, var(--color-brand-deep));
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.55), 0 8px 22px rgb(19 50 143 / 0.55);
  }
</style>

<script>
  import { initReveal } from '@/lib/reveal';
  initReveal();

  const menu = document.querySelector('.menu-icon');
  document.querySelector('[data-menu-toggle]')?.addEventListener('click', () => {
    menu?.setAttribute('data-open', menu.getAttribute('data-open') === 'true' ? 'false' : 'true');
  });

  const check = document.querySelector('.icon-draw');
  check?.classList.add('is-drawn');
  document.querySelector('[data-check-replay]')?.addEventListener('click', () => {
    if (!check) return;
    check.classList.remove('is-drawn');
    void check.getBoundingClientRect();
    check.classList.add('is-drawn');
  });
</script>
