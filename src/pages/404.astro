---
// Custom 404 — refined with branding/links in Phase 7 (P7-T5).
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Page not found">
  <section class="mx-auto flex max-w-prose flex-col items-start px-6 py-24">
    <p class="text-sm font-medium text-white/50">404</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">Page not found</h1>
    <p class="mt-3 text-white/70">That page doesn't exist. Let's get you back on track.</p>
    <a
      href="/"
      class="mt-8 inline-flex min-h-11 items-center rounded-lg bg-white px-5 font-medium text-black"
    >
      Back to home
    </a>
  </section>
</Layout>
