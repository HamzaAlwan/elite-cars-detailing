---
// P7-T5 — Custom 404 with branding, links back to home and booking.
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/Button.astro';
import { SITE, CTA } from '@/data/site';
---

<Layout
  title={`Page not found — ${SITE.name}`}
  description="The page you were looking for doesn't exist. Return home or book a detail."
>
  <section class="flex min-h-[100svh] flex-col items-center justify-center px-6 text-center">
    <p class="text-sm font-medium tracking-widest text-brand uppercase">404</p>
    <h1 class="mt-3 text-h2 font-bold tracking-tight text-text">Page not found</h1>
    <p class="mt-3 max-w-md text-text-muted">
      That page doesn't exist — it may have moved or the link was mistyped. Let's get you back on
      track.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href="/">{CTA.book}</Button>
      <Button href="/#pricing" variant="ghost">See our packages</Button>
    </div>
    <p class="mt-12 text-sm text-text-muted">
      <a href="/" class="text-brand underline-offset-4 hover:underline">← Back to {SITE.name}</a>
    </p>
  </section>
</Layout>
